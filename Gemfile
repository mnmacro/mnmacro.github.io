source "https://rubygems.org"

# Local preview uses modern Jekyll (Ruby 3.4+ compatible).
# GitHub Pages builds the deployed site on its own infrastructure with the
# `github-pages` toolchain — no Gemfile pin needed.
gem "jekyll", "~> 4.3"
gem "webrick", "~> 1.8"

# Standard-library gems unbundled in Ruby 3.4+ that Jekyll/Liquid still import
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
